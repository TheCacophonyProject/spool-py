#!/bin/bash

set -e
outDir=./mpy
srcPath=./src

mpyVersion=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mpy-version)
            mpyVersion="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

if [[ -n "$mpyVersion" ]]; then
    echo "Installing mpy-cross==$mpyVersion..."
    if ! pip install --quiet "mpy-cross==$mpyVersion"; then
        echo "pip install failed. Try installing via pipx instead:"
        echo "  sudo apt install pipx"
        echo "  pipx install mpy-cross==$mpyVersion"
        exit 1
    fi
fi

echo "Cleaning $outDir..."
rm -rf $outDir
mkdir $outDir

echo "Compiling .py files to .mpy..."
for f in "$srcPath"/*; do
    base="$(basename "$f")"
    if [[ "$f" == *.py && "$base" != "main.py" && "$base" != code*.py ]]; then
        mpy-cross "$f" -o "$outDir/${base%.py}.mpy"
    else
        cp "$f" "$outDir/$base"
    fi
done

echo "Finished compiling .py files to .mpy."
