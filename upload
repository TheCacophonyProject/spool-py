#!/bin/bash

run_main=false

for arg in "$@"; do
    case "$arg" in
        --run-main) run_main=true ;;
        *) echo "Unknown argument: $arg"; exit 1 ;;
    esac
done

scriptDir="$(cd "$(dirname "$0")" && pwd)"
srcPath="$scriptDir/src"

if [ ! -d "$srcPath" ]; then
    echo "'$srcPath' is not a valid directory."
    exit 1
fi

prescript="$scriptDir/pre-script.py"
if [ -f "$prescript" ]; then
    echo "Running pre script."
    python "$prescript"
    echo "Finished running pre script."
fi

echo "Clearing Pico filesystem..."
mpremote exec "import os; [os.remove(f) for f in os.listdir() if not os.stat(f)[0] & 0x4000]"

echo "Copying files from $srcPath..."
mpremote cp "$srcPath"/* :

if [ "$run_main" = true ]; then
    echo "Running main.py..."
    mpremote run "$srcPath/main.py"
else
    echo "Resetting Pico..."
    mpremote reset
fi
