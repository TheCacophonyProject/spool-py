#!/bin/bash

port=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--port) port="$2"; shift 2 ;;
        *) echo "Unknown argument: $1"; exit 1 ;;
    esac
done

mpremote() {
    if [ -n "$port" ]; then
        command mpremote "$port" "$@"
    else
        command mpremote "$@"
    fi
}

scriptDir="$(cd "$(dirname "$0")" && pwd)"
srcPath="$scriptDir/src"

if [ ! -d "$srcPath" ]; then
    echo "'$srcPath' is not a valid directory."
    exit 1
fi

prescript="$scriptDir/pre-script.py"
if [ -f "$prescript" ]; then
    echo "Running pre script."
    python "$prescript"
    echo "Finished running pre script."
fi

tmpDir=./mpy

./compile-mpy

echo "Clearing Pico filesystem..."
mpremote exec "import os; [os.remove(f) for f in os.listdir() if not os.stat(f)[0] & 0x4000]"

echo "Copying files from $tmpDir..."
mpremote cp "$tmpDir"/* :

echo "Resetting Pico..."
mpremote reset
sleep 2
while true; do
    mpremote repl 2>/dev/null
    [ $? -eq 0 ] && break
    echo "Device reset, reconnecting..."
    sleep 2
done
