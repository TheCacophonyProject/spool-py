#!/bin/bash

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
    echo "Usage: $0 <directory> [script_to_run]"
    exit 1
fi

directory="$1"
scriptToRun="${2:-}"

if [ ! -d "$directory" ]; then
    echo "'$directory' is not a valid directory."
    exit 1
fi

pyboardPath="$directory/pyboard"
if [ ! -d "$pyboardPath" ]; then
    echo "'$pyboardPath' is not a valid directory."
    exit 1
fi

# Run pre-script if present
prescript="$directory/pre-script.py"
if [ -f "$prescript" ]; then
    echo "Running pre script."
    python "$prescript"
    echo "Finished running pre script."
fi

echo "Clearing Pico filesystem..."
mpremote exec "import os; [os.remove(f) for f in os.listdir() if not os.stat(f)[0] & 0x4000]"

echo "Copying files from $pyboardPath..."
mpremote cp "$pyboardPath"/* :

if [ -n "$scriptToRun" ]; then
    echo "Running $scriptToRun on Pico..."
    mpremote run "$pyboardPath/$scriptToRun"
else
    echo "Resetting Pico..."
    mpremote reset
fi
